+        let picker_width = if render_preview {
+            self.last_area.width / 2
+        } else {
+            self.last_area.width
+        };
+        let over_picker = event.column < self.last_area.x.saturating_add(picker_width);
+        match event.kind {
+            MouseEventKind::ScrollUp if over_picker => {
+                self.move_by(3, Direction::Backward);
+            }
+            MouseEventKind::ScrollDown if over_picker => {
+                self.move_by(3, Direction::Forward);
+            }
+            MouseEventKind::Down(MouseButton::Left) if over_picker => {
+                self.select_picker_row(event.row);
+            }
+            MouseEventKind::Down(MouseButton::Left) => {
+                self.update_preview_selection(cx.editor, event.row, event.column, false);
+            }
+            MouseEventKind::Drag(MouseButton::Left) => {
+                self.update_preview_selection(cx.editor, event.row, event.column, true);
+            }
+            _ => {}
+        }
+        EventResult::Consumed(None)
+    }
