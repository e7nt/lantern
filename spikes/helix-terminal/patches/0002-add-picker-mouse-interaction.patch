+    }
+
+    fn update_preview_selection(
+        &mut self,
+        editor: &Editor,
+        row: u16,
+        column: u16,
+        extend: bool,
+    ) -> bool {
+        let Some((_preview_area, inner)) = self.preview_areas() else {
+            return false;
+        };
+        if row < inner.top()
+            || row >= inner.bottom()
+            || column < inner.left()
+            || column >= inner.right()
+        {
+            return false;
+        }
+        let previous = self.preview_selection;
+        let Some((preview, range)) = self.get_preview(editor) else {
+            return false;
+        };
+        let Some(doc) = preview.document() else {
+            return false;
+        };
+        if range.is_some_and(|(start, end)| start > end || end > doc.text().len_lines()) {
+            return false;
+        }
+        let offset = preview_view_position(doc, range, inner);
+        let text = doc.text().slice(..);
+        let text_fmt = doc.text_format(inner.width, None);
+        let annotations = TextAnnotations::default();
+        let visual_row = usize::from(row - inner.y).saturating_add(offset.vertical_offset);
+        let visual_column = usize::from(column - inner.x).saturating_add(offset.horizontal_offset);
+        let (position, virtual_lines) = char_idx_at_visual_offset(
+            text,
+            offset.anchor,
+            visual_row as isize,
+            visual_column,
+            &text_fmt,
+            &annotations,
+        );
+        if virtual_lines != 0 || position > text.len_chars() {
+            return false;
+        }
+        self.preview_selection = Some(if extend {
+            previous
+                .unwrap_or_else(|| Range::point(position))
+                .put_cursor(text, position, true)
+        } else {
+            Range::point(position)
+        });
+        true
+    }
