+    fn select_picker_row(&mut self, row: u16) -> bool {
+        let render_preview = self.show_preview
+            && self.file_fn.is_some()
+            && self.last_area.width > MIN_AREA_WIDTH_FOR_PREVIEW;
+        let picker_width = if render_preview {
+            self.last_area.width / 2
+        } else {
+            self.last_area.width
+        };
+        let picker_area = self.last_area.with_width(picker_width);
+        let table_area = Block::bordered().inner(picker_area).clip_top(2);
+        let content_y = table_area.y.saturating_add(self.header_height());
+        let rows = table_area.height.saturating_sub(self.header_height()) as u32;
+        if row < content_y || row >= content_y.saturating_add(rows as u16) || rows == 0 {
+            return false;
+        }
+        let snapshot = self.matcher.snapshot();
+        let offset = self.cursor - (self.cursor % rows);
+        let index = offset.saturating_add(u32::from(row - content_y));
+        if index >= snapshot.matched_item_count() {
+            return false;
+        }
+        self.cursor = index;
+        self.preview_selection = None;
+        true
+    }
+
+    fn promote_preview_selection(&mut self, cx: &mut Context, action: Action) -> bool {
+        let Some(range) = self.preview_selection.filter(|range| !range.is_empty()) else {
+            return false;
+        };
+        let Some(option) = self.selection() else {
+            return false;
+        };
+        (self.callback_fn)(cx, option, action);
+        let (view, doc) = current!(cx.editor);
+        if range.to() > doc.text().len_chars() {
+            cx.editor
+                .set_error("preview selection no longer matches the opened document");
+            return false;
+        }
+        doc.set_selection(view.id, Selection::single(range.anchor, range.head));
+        self.preview_selection = None;
+        true
+    }
