+fn lantern_navigate(
+    cx: &mut compositor::Context,
+    args: Args,
+    event: PromptEvent,
+) -> anyhow::Result<()> {
+    if event != PromptEvent::Validate {
+        return Ok(());
+    }
+
+    let path = helix_stdx::path::expand_tilde(Path::new(&args[0]));
+    let parse_coordinate = |value: &str, name: &str| -> anyhow::Result<usize> {
+        value
+            .parse::<usize>()?
+            .checked_sub(1)
+            .with_context(|| format!("{name} must be one or greater"))
+    };
+    let start_line = parse_coordinate(&args[1], "start line")?;
+    let start_column = parse_coordinate(&args[2], "start column")?;
+    let end_line = parse_coordinate(&args[3], "end line")?;
+    let end_column = parse_coordinate(&args[4], "end column")?;
+
+    cx.editor.open(&path, Action::Replace)?;
+    let (view, doc) = current!(cx.editor);
+    let text = doc.text().slice(..);
+    let start = pos_at_coords(text, (start_line, start_column).into(), true);
+    let end = pos_at_coords(text, (end_line, end_column).into(), true);
+    if end <= start {
+        bail!("Lantern evidence range must end after it starts");
+    }
+
+    doc.set_selection(view.id, Selection::single(start, end));
+    align_view(doc, view, Align::Center);
+    Ok(())
+}
