index 63ef6d03..b14f235d 100644
--- a/helix-view/src/document.rs
+++ b/helix-view/src/document.rs
@@ -1974,6 +1974,25 @@ impl Document {
         })
     }
 
+    pub fn language_server_handles_with_feature(
+        &self,
+        feature: LanguageServerFeature,
+    ) -> impl Iterator<Item = Arc<helix_lsp::Client>> + '_ {
+        self.language_config().into_iter().flat_map(move |config| {
+            config.language_servers.iter().filter_map(move |features| {
+                let language_server = self.language_servers.get(&features.name)?.clone();
+                if language_server.is_initialized()
+                    && language_server.supports_feature(feature)
+                    && features.has_feature(feature)
+                {
+                    Some(language_server)
+                } else {
+                    None
+                }
+            })
+        })
+    }
+
     pub fn supports_language_server(&self, id: LanguageServerId) -> bool {
         self.language_servers().any(|l| l.id() == id)
     }
