#!/usr/bin/env bash

set -euo pipefail

: "${TMUX:?Lantern pane focus requires the Lantern tmux session}"
: "${TMUX_PANE:?Lantern editor pane is not configured}"

agent_pane=$(tmux list-panes -t "$TMUX_PANE" -F '#{pane_id} #{pane_title}' |
	awk '$2 == "Lantern" { print $1; exit }')
if [[ -z $agent_pane ]]; then
	echo "Lantern agent pane is not available." >&2
	exit 1
fi

tmux select-pane -t "$agent_pane"
