#!/usr/bin/env bash

set -euo pipefail

: "${TMUX:?Lantern selection capture requires the Lantern tmux session}"
: "${LANTERN_EDITOR_PANE:?Lantern editor pane is not configured}"
: "${LANTERN_SELECTION_PATH:?Lantern selection path is not configured}"

tmux send-keys -t "$LANTERN_EDITOR_PANE" Escape
tmux send-keys -t "$LANTERN_EDITOR_PANE" ':'
if [[ ${1:-} == --exact ]]; then
	command='lantern-export-selection'
else
	command='lantern-export-symbol-context'
fi
tmux send-keys -l -t "$LANTERN_EDITOR_PANE" "$command"
tmux send-keys -t "$LANTERN_EDITOR_PANE" Enter
