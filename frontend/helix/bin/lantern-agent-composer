#!/usr/bin/env bash

set -euo pipefail

: "${TMUX:?Lantern composer requires the Lantern tmux session}"

find_agent_pane() {
	tmux list-panes -t "${TMUX_PANE:?Lantern editor pane is not configured}" \
		-F '#{pane_id} #{pane_title}' |
		awk '$2 == "Lantern" { print $1; exit }'
}

submit_question() {
	local agent_pane=$1
	local question=$2
	local action=${3:-question}
	[[ -n ${question//[[:space:]]/} ]] || return 0
	: "${LANTERN_SUBMIT_BIN:?Lantern submit client is not configured}"
	: "${LANTERN_CONTROL_SOCKET:?Lantern control socket is not configured}"
	local -a submit_args=()
	if [[ $action == plan-comment ]]; then
		submit_args+=(--plan-comment)
	fi
	if ! printf '%s' "$question" | "$LANTERN_SUBMIT_BIN" "${submit_args[@]}"; then
		printf '\n\n  Lantern could not receive the question. Press Enter to close.' >&2
		IFS= read -r _ || true
		return 1
	fi
	tmux select-pane -t "$agent_pane"
}

if [[ ${1:-} == --prompt ]]; then
	: "${LANTERN_AGENT_PANE:?Lantern agent pane is not configured}"
	cleanup_review=false
	trap 'if $cleanup_review; then rm -f "${LANTERN_REVIEW_PATH:-}"; fi' EXIT
	if [[ -s ${LANTERN_REVIEW_PATH:-} ]]; then
		label="Ask about the selected Git change"
		cleanup_review=true
	elif [[ -s ${LANTERN_SELECTION_PATH:-} ]]; then
		label="Ask about the selected code"
	else
		label="Ask about this repository"
	fi
	printf '\n  %s\n  Enter ask · Ctrl-r add plan comment\n\n  › ' "$label"
	if [[ -t 0 ]]; then
		bind '"\C-r":"\C-e __LANTERN_PLAN_COMMENT__\n"'
		IFS= read -e -r question || exit 0
	else
		IFS= read -r question || exit 0
	fi
	[[ -n ${question//[[:space:]]/} ]] || exit 0
	action=question
	if [[ $question == *' __LANTERN_PLAN_COMMENT__' ]]; then
		question=${question%' __LANTERN_PLAN_COMMENT__'}
		action=plan-comment
	fi
	submit_question "$LANTERN_AGENT_PANE" "$question" "$action"
	cleanup_review=false
	exit 0
fi

agent_pane=$(find_agent_pane)
if [[ -z $agent_pane ]]; then
	echo "Lantern agent pane is not available." >&2
	exit 1
fi

printf -v popup_command '%q --prompt' "$0"
tmux display-popup -t "$TMUX_PANE" -E -w '70%' -h 8 \
	-T ' Ask Lantern ' \
	-e "LANTERN_AGENT_PANE=$agent_pane" \
	-e "LANTERN_SELECTION_PATH=${LANTERN_SELECTION_PATH:-}" \
	-e "LANTERN_REVIEW_PATH=${LANTERN_REVIEW_PATH:-}" \
	-e "LANTERN_CONTROL_SOCKET=${LANTERN_CONTROL_SOCKET:?}" \
	-e "LANTERN_SUBMIT_BIN=${LANTERN_SUBMIT_BIN:?}" \
	"$popup_command"
